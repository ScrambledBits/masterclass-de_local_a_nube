# Unidad systemd para el servicio FastAPI (uvicorn).
# systemd es el estándar en Linux moderno para gestionar procesos como servicios:
# auto-inicio con el sistema, reinicio ante fallos, logs centralizados en journald.
#
# Las variables entre {{ }} son reemplazadas por Ansible desde group_vars/all.yml.

[Unit]
Description=Backend App FastAPI/uvicorn — Masterclass CI/CD
# Esperar a que la red esté disponible antes de iniciar
After=network.target

[Service]
Type=simple
User={{ app_user }}
WorkingDirectory={{ app_dir }}
# Usamos el uvicorn del venv, no el del sistema — consistencia garantizada
ExecStart={{ app_dir }}/venv/bin/uvicorn main:app --host 0.0.0.0 --port {{ app_port }}
# Reinicio automático tras 3 segundos en caso de fallo
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
