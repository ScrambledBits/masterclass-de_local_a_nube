# Configuración de Nginx: sirve el frontend estático y hace proxy al backend.
# Esta plantilla Jinja2 materializa el diagrama de arquitectura:
#   Internet → Nginx (Puerto 80) → HTML/JS estático  (location /)
#                                → FastAPI (Puerto 5000, subred privada)  (location /api/)
#
# 'backend_private_ip' y 'app_port' son inyectados por Ansible via --extra-vars
# desde los outputs de Terraform.

server {
    listen 80;
    server_name _;  # '_' acepta cualquier nombre de host (valido para IP directa)

    root /var/www/html;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        # Trailing slash en proxy_pass elimina el prefijo /api/ antes de reenviar.
        # FastAPI recibe GET / y GET /health (sin /api/).
        # El usuario no puede llegar directamente a :5000 (solo Nginx puede).
        proxy_pass http://{{ backend_private_ip }}:{{ app_port }}/;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
